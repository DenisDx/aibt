{
  // aibt configuration example.
  // Copy this file to config.json5 and adjust as needed.
  // Private/machine-specific values are loaded from .env via ${VAR:-default} placeholders.

  "version": "1.0",
  "title": "aibt 1",

  // Unique instance identifier (matches service name and docker container names).
  "instance": "${AIBT_INSTANCE:-aibt}",

  // Absolute path to project root. Set automatically by install.sh.
  "root": "${AIBT_ROOT}",

  // How often cron.py is expected to be invoked, in seconds.
  "cron_period": ${CRON_PERIOD:-60},

  "logging": {
    // Default log level for all subsystems. String or int (0-7, systemd-journald scale).
    // 0=emergency 1=alert 2=critical 3=error 4=warning 5=notice 6=info 7=debug
    "level": "${LOG_LEVEL:-info}",

    // Timezone for log timestamps.
    // "local" = server local timezone, "UTC", or IANA zone name (e.g. "Europe/Moscow").
    "timezone": "${LOG_TIMEZONE:-local}",

    // Seconds between log wipe runs. 0 = never wipe.
    "wipe_period": ${LOG_WIPE_PERIOD:-3600},

    // Maximum age of log lines in seconds before they are wiped.
    "wipe_max_age": ${LOG_WIPE_MAX_AGE:-2592000},

    // Maximum size in bytes for individual log files. 0 = unlimited.
    "max_log_size": ${MAX_LOG_SIZE:-10485760},

    // Persist LLM prompts/responses to logs/<agent>_llm.jsonl when enabled per agent.
    "log_llm": false,

    // Per-subsystem level overrides. Unspecified subsystems use "level" above.
    "levels": {
      "core": "info",
      "webui": "info",
      "cron": "info",
      "memoryd": "info",
      "agents": "warning",
      "mcp": "warning",
    },
  },

  // Agent system configuration (used from phase 2 onward).
  "agents": {
    "orchestrator": {
      "max_retries": 1,  // Retry attempts after the first failed execution.
      "retry_delay_sec": 0.5,  // Delay between retry attempts in seconds.
      "fallback_agent": "echo",  // Agent used after retries are exhausted.
    },
    "items": {
      "echo": { "enabled": true },  // Enable simple echo test agent.
      "math": { "enabled": true },  // Enable simple math test agent.
      "graph_echo": { "enabled": true },  // Enable LangGraph-based echo test agent.
      "chat_group_helper": {
        "enabled": true,  // Enable conservative group helper agent.
        // "tools": ["search", "fetch"],  // Optional raw tools passthrough to this agent's direct LLM requests.
        "recent_messages_limit": 50,  // Recent message count included into model context.
        "memoryd": {
          "context_types": ["semantic", "episodic", "summaries", "profiles"],  // Types to attach into prompt context from memoryd.
          "update_types": ["semantic", "episodic", "summaries", "profiles"]  // Types to enqueue for memoryd update processing.
        },
        "logging": {
          "log_llm": true  // Persist LLM request/response rows for this agent.
        }
      },
      "chat_group_helper2": {
        "enabled": false,  // Enable two-stage gate+delegate helper agent.
        // "tools": ["search", "fetch"],  // Optional raw tools passthrough to gate stage direct LLM requests.
        "gate": {
          "provider": "${FAST_LLM_PROVIDER:-default}",  // Provider key used by gate stage.
          "model": "${FAST_LLM_MODEL:-gpt-4o-mini}",  // Fast gate model id.
          "instruction_files": [
            "${AIBT_ROOT}/agent_files/chat_group_helper2.md"
          ],  // Gate instruction files appended to system prompt.
          "fail_mode": "fail_closed"  // Gate failure policy: fail_closed or fail_open.
        },
        "delegate_agent": "chat_group_helper",  // Smart delegate agent id after gate accepts.
        "recent_messages_limit": 50,  // Recent message count used to build gate context.
        "memoryd": {
          "context_types": ["semantic", "episodic", "summaries", "profiles"],  // Types to attach into prompt context from memoryd.
          "update_types": ["semantic", "episodic", "summaries", "profiles"]  // Types to enqueue for memoryd update processing.
        },
        "logging": {
          "log_llm": true  // Persist LLM request/response rows for this agent.
        }
      },
      // Example per-agent corpus allowlist.
      // "researcher": {  // Example agent id with corpus allowlist.
      //   "enabled": true,  // Enable this example agent.
      //   "rag": {  // Per-agent RAG settings block.
      //     "corpora": ["shared", "research-private"]  // Allowed corpora for this agent.
      //   }
      // },
      // Example: per-agent config override.
      // "myagent": {  // Example custom agent id.
      //   "config": {  // Overlay config applied only to this agent.
      //     "logging": { "levels": { "agents": 3 } }  // Per-agent subsystem log level override.
      //   }
      // }
    },
  },

  // External MCP servers (used from phase 3 onward).
  "mcp": {
    "items": {
      // "mcp1": {  // MCP server id.
      //   "tools_list": ["search", "fetch"],  // Allowed tool names for this server.
      //   "auth": { "token": "${MCP1_TOKEN}" },  // Optional auth payload for server connection.
      // }
    },
  },

  // LLM provider definitions (used from phase 2 onward).
  "models": {
    "active_provider": "default",
    "active_model": "${LLM_MODEL:-gpt-4o-mini}",
    "providers": {
      "default": {
        "baseUrl": "${LLM_BASE_URL:-https://api.openai.com/v1}",
        "apiKey": "${LLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "${LLM_MODEL:-gpt-4o-mini}", "name": "${LLM_MODEL:-gpt-4o-mini}" }
        ]
      }
    },
  },

  // Memory and RAG configuration.
  "memory": {
    "enabled": true,

    // All internal memory data and indexes stay under project root.
    "path": "memory/runtime",

    // External document storages. Agents access documents only via memory API tools.
    "document_storages": {
      "items": {
        "default": {
          "type": "filesystem",
          "root": "${AIBT_ROOT}/data/documents_external",
          "read_only": false,
        },
      },
    },

    "rag": {
      "enabled": true,
      // Optional embedding vector dimension override (fallback when retrieval.embedding_dim is absent).
      // "embedding_dim": 256,  // Optional global embedding dimension override.
      "ingest": {
        // Process queued jobs only in cron, while system is mostly idle.
        "max_jobs_per_tick": 3,
        "chunk_size": 1200,
        "chunk_overlap": 120,
      },
      "retrieval": {
        "default_limit": 8,
        "embedding_dim": 256,
        "lexical_weight": 0.45,
        "dense_weight": 0.55,
        "lexical_top_k": 32,
        "dense_top_k": 32,
      },
    },

    "langmem": {
      "enabled": true,
      "summary_inactive_after_hours": 24,
      "archive_after_hours": 72,
      "retain_recent_episodes": 150,
      "min_semantic_importance": 0.7,
      "max_semantic_promotions_per_tick": 8,
      "max_archives_per_tick": 8,
    },
  },

  // Memoryd configuration (optional; enabled by an envid overlay below).
  "memoryd": {
    "enabled": false,
    "provider": "default",
    "model": "${LLM_MODEL:-gpt-4o-mini}",
    // Agent-level policy can narrow active memoryd types by stage:
    // agents.items.<agent>.memoryd.context_types and .update_types
    "max_sim_task": 1,
    "memory_task_prio": 8,
    "muid": "default",
    "queue": {
      "cancel_policy": "cancel_previous_same_muid",
      "max_pending": 10000,
    },
    "items": {
      "episodic": {
        "enabled": true,
        "max_record_count": 30,
        "max_content_length": 8196,
      },
      "semantic": {
        "enabled": true,
        "max_record_count": 50,
        "max_content_length": 8196,
      },
      "summaries": {
        "enabled": true,
        "max_record_count": 10,
        "max_content_length": 8196,
      },
      "profiles": {
        "enabled": true,
        "max_record_count": 50,
        "max_content_length": 8196,
      },
    },
  },

  // Web UI configuration.
  "webui": {
    "port": ${WEBUI_PORT:-50080},
    "bind": "${WEBUI_HOST:-0.0.0.0}",
    "auth": {
      "mode": "login",
      "session_ttl": 86400,
      "users": [
        {
          "login": "${ROOT_USER:-admin}",
          "password": "${ROOT_PASSWORD:-admin}",
          "permissions": ["all"],
        },
      ],
    },
  },

  // Adapter configuration (external integrations: Telegram, Cron, etc).
  "adapters": {
    "items": {
      "telegram": {
        "enabled": false,  // Set to true and provide TELEGRAM_BOT_TOKEN to enable
        "token": "${TELEGRAM_BOT_TOKEN}",  // Telegram Bot token from @BotFather
        "default_agent": "chat_group_helper",  // Agent to use for Telegram messages
        "show_typing": false,  // Show typing indicator while waiting for agent response
        "polling": true,  // Use polling (true) or webhook (false)
        "polling_timeout": 30,  // Polling timeout in seconds
        // "groupPolicy": "allowlist",  // Legacy compatibility key from older Telegram routing policies.
        // "streaming": "partial",  // Legacy compatibility key for partial streaming modes.
        "timeoutSeconds": 100,  // Max wait for one agent task before silent skip
        // "max_waiting_time": 100,  // Planned queue-wait timeout before watchdog terminates non-started tasks.
        "listen_private": true,  // Listen to private chats
        "listen_groups": true,  // Listen to groups/supergroups where bot is added
        // "allow_groups_list": [-1001234567890],  // Optional adapter ACL: when set, only listed group chat_ids are allowed; [] blocks all groups
        // "allow_users_list": [123456789, "allowed_username"],  // Optional adapter ACL: when set, only listed sender user ids/usernames are allowed
        "dialog_log_type": "telegram_dialog",  // Dedicated file logs/<dialog_log_type>.log with input+reaction pairs
        // Example with graph_echo agent:
        // "enabled": true,  // Enable Telegram adapter.
        // "token": "${TELEGRAM_BOT_TOKEN}",  // Telegram bot token.
        // "default_agent": "graph_echo",  // Default agent for incoming Telegram messages.
        // "polling": true,  // Use polling instead of webhook mode.
        // "polling_timeout": 30,  // Long polling timeout in seconds.
        // "listen_private": true,  // Accept private chats.
        // "listen_groups": true,  // Accept group and supergroup chats.
        // "allow_groups_list": [-1001234567890],  // Optional group ACL allowlist.
        // "allow_users_list": [123456789, "allowed_username"],  // Optional sender ACL allowlist.
        // "dialog_log_type": "telegram_dialog",  // Dedicated log type for dialog input/output records.
      },
      "cron": {
        "enabled": true,  // Enable cron adapter registration.
      },
    },
  },

  // Optional environment overlays for per-chat/per-tenant behavior.
  "envids": {
    "enabled": true,
    "strict_matching": false,
    // Optional deterministic order. Remaining items follow declaration order.
    "startup_order": [
      // "group_alpha",  // Example envid id in explicit startup order.
      // "group_beta"  // Example envid id in explicit startup order.
    ],
    // Optional per-adapter order overrides.
    "adapter_startup_order": {
      // "telegram": ["group_alpha", "group_beta"]  // Adapter-specific envid startup order.
    },
    "items": {
      "envid-telegram-bot2-memoryd": {
        "title": "Telegram bot2 memoryd routing",  // Human-readable overlay title.
        "matching": {
          "adapters": {
            "telegram": {
              "chat_ids": [-5090882533]  // Telegram chat id reserved for memoryd smoke/testing.
            }
          }
        },
        "runtime": { "enabled": true },  // Enable this envid runtime overlay.
        "config": {
          "memory": {
            "enabled": false  // Disable legacy memory for this envid.
          },
          "memoryd": {
            "enabled": true,  // Enable memoryd for this envid.
            "requests": [
              {
                "types": ["episodic", "semantic", "summaries", "profiles"],
                "request_file": "${AIBT_ROOT}/agent_files/memoryd_episodic_semantic_summaries_profiles.md"
              }
            ]
          }
        }
      },
      "envid-telegram-bot2": {
        "title": "Telegram bot2 routing",  // Human-readable overlay title.
        "matching": {
          "adapters": {
            "telegram": {
              "chat_types": ["private", "group", "supergroup"]  // Telegram chat types matched by this envid.
            }
          }
        },
        "runtime": { "enabled": true },  // Enable this envid runtime overlay.
        "config": {
          "adapters": {
            "items": {
              "telegram": {
                "default_agent": "chat_group_helper2"  // Override default Telegram agent under this envid.
              }
            }
          },
          "agents": {
            "items": {
              "chat_group_helper2": {
                "enabled": true  // Ensure delegate target agent is enabled under this envid.
              }
            }
          }
        }
      },
      // "group_alpha": {  // Example additional envid id.
      //   "title": "Telegram group alpha",  // Human-readable overlay title.
      //   "matching": {  // Event matching rules for this envid.
      //     "adapters": {  // Per-adapter matcher rules.
      //       "telegram": {  // Telegram-specific matcher block.
      //         "chat_ids": [-1001234567890],  // Matched Telegram chat ids.
      //         "chat_usernames": ["group_alpha"],  // Matched Telegram chat usernames.
      //         "chat_types": ["group", "supergroup"]  // Matched Telegram chat types.
      //       }
      //     }
      //   },
      //   "runtime": { "enabled": true },  // Enable this envid runtime overlay.
      //   "config": {  // Overlay config applied when this envid matches.
      //     "adapters": {  // Adapter config overlay section.
      //       "items": {  // Adapter instances map.
      //         "telegram": { "default_agent": "echo" }  // Override Telegram default agent for this envid.
      //       }
      //     },
      //     "agents": {  // Agent config overlay section.
      //       "items": {  // Agent instances map.
      //         "echo": {  // Target agent id under this envid.
      //           "instruction_files": ["${AIBT_ROOT}/agent_files/group_alpha.md"]  // Envid-specific instruction files.
      //         }
      //       }
      //     }
      //   }
      // }
    }
  },

  // Cron adapter configuration (for scheduled task execution).
  "cron": {
    "enabled": true,  // Enable cron task runner section.
    // Optional legacy schedule list consumed by CronAdapter (kept for compatibility).
    // "schedules": [],  // Optional legacy schedule list consumed by CronAdapter.
    "tasks": [
      // Example scheduled task (requires schedule parsing):
      // {
      //   "name": "daily_math",  // Task id/name used in logs.
      //   "enabled": true,  // Enable this scheduled task.
      //   "agent": "math",  // Target agent id executed by this task.
      //   "schedule": "0 9 * * *",  // daily at 09:00 (cron syntax)
      //   "message": "Calculate the answer to the universe"  // Input message/query sent to target agent.
      // },
      // {
      //   "name": "hourly_check",  // Task id/name used in logs.
      //   "enabled": false,  // Enable this scheduled task.
      //   "agent": "echo",  // Target agent id executed by this task.
      //   "schedule": "0 * * * *",  // every hour
      //   "message": "System check"  // Input message/query sent to target agent.
      // }
    ],
  },

  // PostgreSQL connection (used from phase 4 onward; container is set up in phase 1).
  "database": {
    "host": "${PG_HOST:-127.0.0.1}",  // PostgreSQL host.
    "port": ${PG_PORT:-5432},  // PostgreSQL port.
    "user": "${PG_USER:-aibt}",  // PostgreSQL user.
    "password": "${PG_PASSWORD}",  // PostgreSQL password.
    "db": "${PG_DB:-aibt}",  // PostgreSQL database name.
  },
}
