# Instance identifier; multiple aibt instances on the same host are supported.
# install.sh will auto-increment suffix (aibt2, aibt3...) if this name is taken.
AIBT_INSTANCE=aibt

# Absolute path to project root. MUST be set by install.sh on first install.
AIBT_ROOT=/home/user/aibt

# ─── Web UI ─────────────────────────────────────────────────
WEBUI_PORT=50080
WEBUI_HOST=0.0.0.0
ROOT_USER=admin
ROOT_PASSWORD=admin

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TIMEZONE=local
LOG_WIPE_PERIOD=3600
LOG_WIPE_MAX_AGE=2592000
MAX_LOG_SIZE=10485760

# ─── Cron ───────────────────────────────────────────────────
CRON_PERIOD=60

# ─── PostgreSQL (docker container) ──────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=aibt
PG_PASSWORD=changeme_aibt_db
PG_DB=aibt

# ─── LLM provider (OpenAI-compatible) ─────────────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=changeme_llm_api_key
LLM_MODEL=gpt-4o-mini

# Optional dual-stage helper model overrides.
FAST_LLM_PROVIDER=default
FAST_LLM_MODEL=gpt-4o-mini
SMART_LLM_PROVIDER=default
SMART_LLM_MODEL=gpt-4o-mini
